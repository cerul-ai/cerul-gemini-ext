{
  "name": "cerul",
  "version": "1.0.0",
  "description": "The video search layer for AI agents. Search video by meaning — across speech, visuals, and on-screen text.",
  "contextFileName": "GEMINI.md",
  "mcpServers": {
    "cerul": {
      "command": "node",
      "args": ["${extensionPath}/scripts/mcp-server.mjs"],
      "cwd": "${extensionPath}",
      "env": {
        "CERUL_API_KEY": "${CERUL_API_KEY}",
        "CERUL_API_URL": "${CERUL_API_URL}"
      }
    }
  },
  "settings": [
    {
      "name": "API Key",
      "description": "Your Cerul API key — get one free at https://cerul.ai/dashboard",
      "envVar": "CERUL_API_KEY",
      "sensitive": true
    },
    {
      "name": "API URL",
      "description": "Cerul API endpoint",
      "envVar": "CERUL_API_URL",
      "default": "https://api.cerul.ai"
    }
  ]
}
